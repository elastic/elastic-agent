#!/bin/bash

set -euo pipefail

checkout_merge() {
    local target_branch=$1
    local merge_branch=$2

    if [[ -z "${target_branch}" ]]; then
        echo "No pull request target branch"
        exit 1
    fi

    git fetch -v origin "${target_branch}"
    local fetched_sha
    fetched_sha=$(git rev-parse FETCH_HEAD)

    # Pin the base branch SHA in build metadata so all parallel jobs merge against
    # the same base, preventing flakiness when the target branch advances mid-build
    # (e.g. an automated NOTICE.txt update landing between packaging and testing jobs).
    local metadata_key="base_sha_${target_branch//\//_}"
    local pinned_sha
    pinned_sha=$(buildkite-agent meta-data get "${metadata_key}" 2>/dev/null || {
        buildkite-agent meta-data set "${metadata_key}" "${fetched_sha}"
        echo "${fetched_sha}"
    })

    # Sparse-checkout pipeline-upload steps use a shallow clone: they have the
    # working-tree files they need but lack the history required for a 3-way
    # merge.  Unshallow so git can locate the merge base and access the blob
    # versions it needs for conflict resolution.  git only downloads objects
    # absent from the local store, so tip blobs already present from the
    # depth-1 fetch are not re-transferred.  Full checkouts skip this block.
    if [[ "$(git rev-parse --is-shallow-repository 2>/dev/null)" == "true" ]]; then
        echo "Shallow repository detected; unshallowing to enable merge"
        git fetch --unshallow origin
    fi

    # Create the merge branch from the current HEAD (the PR commit Buildkite
    # already checked out) and merge the pinned base into it, rather than
    # checking out the base and merging the PR in.  The resulting tree is
    # identical, but this avoids a full working-tree switch to a different
    # commit, which would trigger submodule working-tree updates that fail
    # when the submodule directory is absent (e.g. beats/ in sparse-checkout
    # pipeline-upload steps).
    git checkout -b "${merge_branch}"
    echo "New branch created: $(git rev-parse --abbrev-ref HEAD)"

    # set author identity so it can be run git merge
    git config user.name "github-merged-pr-post-checkout"
    git config user.email "auto-merge@buildkite"

    # When the beats submodule directory is absent (sparse-checkout steps),
    # suppress the submodule working-tree update that would otherwise fail.
    local -a merge_flags=()
    if [[ ! -e beats ]]; then
        merge_flags+=(-c submodule.recurse=false)
    fi

    git "${merge_flags[@]}" merge --no-edit "${pinned_sha}" || {
        local merge_result=$?
        echo "Merge failed: ${merge_result}"
        git merge --abort
        exit ${merge_result}
    }
}

pull_request="${BUILDKITE_PULL_REQUEST:-false}"

if [[ "${pull_request}" == "false" ]]; then
    echo "Not a pull request, skipping"
    exit 0
fi

TARGET_BRANCH="${BUILDKITE_PULL_REQUEST_BASE_BRANCH:-master}"
PR_ID=${BUILDKITE_PULL_REQUEST}
MERGE_BRANCH="pr_merge_${PR_ID}"

checkout_merge "${TARGET_BRANCH}" "${MERGE_BRANCH}"

echo "Commit information"
git --no-pager log --format=%B -n 1

# Ensure buildkite groups are rendered
echo ""
